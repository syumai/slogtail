{
  "name": "lduck",
  "version": "0.0.2",
  "description": "Pipe-friendly JSON log viewer powered by DuckDB",
  "type": "module",
  "bin": {
    "lduck": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "log",
    "log-viewer",
    "json",
    "duckdb",
    "cli",
    "stdin",
    "pipe",
    "structured-logging"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/syumai/lduck.git"
  },
  "homepage": "https://github.com/syumai/lduck",
  "bugs": {
    "url": "https://github.com/syumai/lduck/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/cli/index.ts",
    "test": "vitest run",
    "lint": "oxlint --type-aware --type-check src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "generate-logs": "node --experimental-strip-types scripts/generate-logs.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.4.4-r.1",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.25.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.14.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-ssr-components": "^0.5.2",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
